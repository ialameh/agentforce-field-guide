<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants the agent user access to the actions for &lt;AgentName&gt;.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>&lt;AgentName&gt; Agent Permissions</label>
    <license>Salesforce</license>
    <classAccesses>
        <apexClass>&lt;ClassName&gt;</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!--
        Add objectPermissions and fieldPermissions here as needed for the
        sObjects and fields the action touches. Example:

        <objectPermissions>
            <object>Account</object>
            <allowRead>true</allowRead>
            <allowEdit>false</allowEdit>
            <allowCreate>false</allowCreate>
            <allowDelete>false</allowDelete>
            <viewAllRecords>false</viewAllRecords>
            <modifyAllRecords>false</modifyAllRecords>
        </objectPermissions>
    -->
</PermissionSet>
